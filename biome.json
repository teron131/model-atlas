{
	"$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!!**/.cache",
			"!!**/.next",
			"!!**/.playwright-cli",
			"!!**/.vercel",
			"!!**/build",
			"!!**/coverage",
			"!!**/dist",
			"!!**/node_modules",
			"!!**/out"
		]
	}
}
