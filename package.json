		"@types/d3-shape": "^3.1.8",
		"@types/node": "^25.0.0",
		"@types/react": "^19.2.16",
		"@types/react-dom": "^19.2.3",
		"playwright": "^1.60.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
