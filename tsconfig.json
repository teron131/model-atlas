{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM"],
		"jsx": "react-jsx",
		"allowJs": true,
		"incremental": true,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": false,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"types": ["node", "react", "react-dom"],
		"noEmit": true
	},
	"include": [
		"next-env.d.ts",
		"app/**/*.ts",
		"app/**/*.tsx",
		"src/**/*.ts",
		"scripts/**/*.ts",
		"test/**/*.ts",
		"next.config.ts",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts"
	],
	"exclude": ["node_modules", ".next"]
}
